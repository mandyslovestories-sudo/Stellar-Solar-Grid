# Copy this file to .env and fill in your values.
# Vite exposes env vars via import.meta.env.VITE_* — NOT process.env.

# Required: Soroban contract address deployed on testnet/mainnet
VITE_CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Soroban RPC endpoint (defaults to testnet if omitted)
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — determines testnet vs mainnet throughout the app
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Backend API base URL (payment history, SMS webhook, etc.)
VITE_BACKEND_URL=http://localhost:3001

# Optional: SMS shortcode and webhook docs (displayed in UI)
VITE_SMS_SHORTCODE=20880
VITE_SMS_WEBHOOK_DOCS=https://github.com/Dev-AdeTutu/Stellar-Solar-Grid/blob/main/backend/README.md
