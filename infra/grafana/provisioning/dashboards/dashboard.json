      "id": 1,
      "title": "MQTT Messages / Min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "rate(solargrid_mqtt_messages_total[1m]) * 60",
          "legendFormat": "Messages/Min",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "Contract Calls by Method/Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (method, status) (rate(solargrid_contract_invocations_total[5m]))",
          "legendFormat": "{{method}} ({{status}})",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "title": "Contract Call Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(solargrid_contract_invocations_total{status=\"error\"}[5m])) / sum(rate(solargrid_contract_invocations_total[5m]))",
          "legendFormat": "Error Rate",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ],
