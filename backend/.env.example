# Required environment variables
PORT=3001
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=YOUR_CONTRACT_ID_HERE
ADMIN_SECRET_KEY=YOUR_ADMIN_SECRET_KEY_HERE
MQTT_BROKER=mqtt://mqtt:1883

# Optional environment variables with defaults
ADMIN_PUBLIC_KEY=YOUR_ADMIN_PUBLIC_KEY_HERE
TELECOM_WEBHOOK_SECRET=YOUR_TELECOM_WEBHOOK_SECRET_HERE
TX_TIMEOUT_MS=30000
TX_MAX_ATTEMPTS=15
TX_POLL_INTERVAL_MS=2000

# Low-balance webhook configuration (optional)
PROVIDER_WEBHOOK_URL=https://example.com/webhook
LOW_BALANCE_THRESHOLD=1000000
